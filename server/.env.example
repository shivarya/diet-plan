# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=diet_plan
DB_USER=root
DB_PASS=

# JWT — generate a long random string for production
JWT_SECRET=change-me-to-a-long-random-secret

# Dev-only login backdoor (POST /auth/login). Keep false in production.
ALLOW_DEV_LOGIN=false

# Google Sign-In — ID tokens are verified against this client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional extra native client IDs (comma-separated)
GOOGLE_ALLOWED_AUDIENCES=

# AI provider (provider-agnostic via utils/aiClient.php). Default: Groq.
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=
#   Swap providers without code changes:
#   AI_PROVIDER=gemini  AI_MODEL=gemini-2.0-flash-lite  GEMINI_API_KEY=...
#   AI_PROVIDER=openai  AI_MODEL=gpt-4o-mini            OPENAI_API_KEY=...
